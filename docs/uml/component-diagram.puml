@startuml
title MoveCodeBeats - Componentes
skinparam componentStyle rectangle

actor Usuario
node Webcam
node Navegador

package "Backend Python" {
  component "Capture\nMediaPipe + OpenCV" as Capture
  component "Processing\nfeatures + gestos" as Processing
  component "Mapping\nparametros musicais" as Mapping
  component "Strudel Domain\nperfis + cenas" as Domain
  component "Application Services" as Services
  component "FastAPI\nREST + WebSocket" as API
}

package "Frontend React" {
  component "API Client" as Client
  component "Interface" as UI
  component "Pattern Builder" as Builder
  component "Strudel Engine" as Engine
}

cloud "WebAudio" as Audio

Usuario --> Webcam
Webcam --> Capture
Capture --> Processing
Processing --> Mapping
Mapping --> Domain
Domain --> Services
Services --> API
API --> Client : JSON / WebSocket
Client --> UI
Client --> Builder : MusicalState
Builder --> Engine : Pattern
Engine --> Audio
Audio --> Usuario
@enduml
